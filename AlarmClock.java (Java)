// AlarmClock.java - Будильник на Java Swing
import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
import java.time.LocalTime;
import java.time.LocalDateTime;
import java.time.temporal.ChronoUnit;
import java.util.Timer;
import java.util.TimerTask;
import javax.sound.sampled.*;
import java.io.*;

public class AlarmClock extends JFrame {
    private JLabel timeLabel;
    private JSpinner hourSpinner, minuteSpinner, secondSpinner;
    private JComboBox<String> repeatBox;
    private JButton setButton, stopButton, snoozeButton;
    private JLabel statusLabel;
    private Timer alarmTimer;
    private LocalTime alarmTime;
    private String repeat;
    private boolean active;
    private Clip clip;

    public AlarmClock() {
        setTitle("⏰ Будильник Java");
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setSize(500, 400);
        setLocationRelativeTo(null);
        setLayout(new BorderLayout(10,10));
        getContentPane().setBackground(new Color(44,62,80));

        // Верхняя панель с текущим временем
        timeLabel = new JLabel("", SwingConstants.CENTER);
        timeLabel.setFont(new Font("Courier New", Font.BOLD, 48));
        timeLabel.setForeground(Color.YELLOW);
        timeLabel.setBackground(Color.BLACK);
        timeLabel.setOpaque(true);
        add(timeLabel, BorderLayout.NORTH);

        // Центр - настройки
        JPanel center = new JPanel(new GridBagLayout());
        center.setOpaque(false);
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(5,5,5,5);
        gbc.gridx=0; gbc.gridy=0;
        center.add(new JLabel("Время:"), gbc);
        gbc.gridx=1;
        hourSpinner = new JSpinner(new SpinnerNumberModel(7,0,23,1));
        center.add(hourSpinner, gbc);
        gbc.gridx=2;
        center.add(new JLabel(":"), gbc);
        gbc.gridx=3;
        minuteSpinner = new JSpinner(new SpinnerNumberModel(0,0,59,1));
        center.add(minuteSpinner, gbc);
        gbc.gridx=4;
        center.add(new JLabel(":"), gbc);
        gbc.gridx=5;
        secondSpinner = new JSpinner(new SpinnerNumberModel(0,0,59,1));
        center.add(secondSpinner, gbc);
        gbc.gridx=0; gbc.gridy=1;
        center.add(new JLabel("Повтор:"), gbc);
        gbc.gridx=1; gbc.gridwidth=4;
        repeatBox = new JComboBox<>(new String[]{"Один раз", "Ежедневно", "По будням"});
        center.add(repeatBox, gbc);
        add(center, BorderLayout.CENTER);

        // Кнопки
        JPanel btnPanel = new JPanel(new FlowLayout());
        btnPanel.setOpaque(false);
        setButton = new JButton("🔔 Установить");
        stopButton = new JButton("🔕 Выключить");
        snoozeButton = new JButton("😴 Отложить (5 мин)");
        btnPanel.add(setButton);
        btnPanel.add(stopButton);
        btnPanel.add(snoozeButton);
        add(btnPanel, BorderLayout.SOUTH);

        statusLabel = new JLabel("Будильник не установлен", SwingConstants.CENTER);
        statusLabel.setForeground(Color.WHITE);
        add(statusLabel, BorderLayout.AFTER_LAST_LINE);

        setButton.addActionListener(e -> setAlarm());
        stopButton.addActionListener(e -> stopAlarm());
        snoozeButton.addActionListener(e -> snooze());

        // Таймер обновления часов
        new Timer().scheduleAtFixedRate(new TimerTask() {
            public void run() {
                SwingUtilities.invokeLater(() -> {
                    timeLabel.setText(LocalTime.now().format(java.time.format.DateTimeFormatter.ofPattern("HH:mm:ss")));
                });
            }
        }, 0, 1000);

        // Проверка будильника
        new Timer().scheduleAtFixedRate(new TimerTask() {
            public void run() {
                if (active && alarmTime != null) {
                    LocalTime now = LocalTime.now();
                    boolean ring = false;
                    if (repeat.equals("Один раз")) {
                        if (now.getHour() == alarmTime.getHour() && now.getMinute() == alarmTime.getMinute() && now.getSecond() == alarmTime.getSecond())
                            ring = true;
                    } else if (repeat.equals("Ежедневно")) {
                        if (now.getHour() == alarmTime.getHour() && now.getMinute() == alarmTime.getMinute() && now.getSecond() == alarmTime.getSecond())
                            ring = true;
                    } else if (repeat.equals("По будням")) {
                        java.time.DayOfWeek dow = LocalDateTime.now().getDayOfWeek();
                        if (dow != java.time.DayOfWeek.SATURDAY && dow != java.time.DayOfWeek.SUNDAY &&
                            now.getHour() == alarmTime.getHour() && now.getMinute() == alarmTime.getMinute() && now.getSecond() == alarmTime.getSecond())
                            ring = true;
                    }
                    if (ring) {
                        ringAlarm();
                        if (repeat.equals("Один раз")) {
                            active = false;
                            SwingUtilities.invokeLater(() -> statusLabel.setText("Будильник отключен"));
                        }
                    }
                }
            }
        }, 0, 500);
    }

    private void setAlarm() {
        int h = (int) hourSpinner.getValue();
        int m = (int) minuteSpinner.getValue();
        int s = (int) secondSpinner.getValue();
        alarmTime = LocalTime.of(h, m, s);
        repeat = (String) repeatBox.getSelectedItem();
        active = true;
        statusLabel.setText(String.format("Будильник установлен на %02d:%02d:%02d (%s)", h,m,s,repeat));
    }

    private void stopAlarm() {
        active = false;
        if (clip != null && clip.isRunning()) clip.stop();
        statusLabel.setText("Будильник выключен");
    }

    private void snooze() {
        if (!active) return;
        LocalTime newTime = LocalTime.now().plusMinutes(5);
        alarmTime = newTime;
        statusLabel.setText(String.format("Отложено до %02d:%02d:%02d", newTime.getHour(), newTime.getMinute(), newTime.getSecond()));
        if (clip != null) clip.stop();
    }

    private void ringAlarm() {
        // Звук
        try {
            if (clip != null) clip.close();
            AudioInputStream audioStream = AudioSystem.getAudioInputStream(new File("alarm.wav"));
            clip = AudioSystem.getClip();
            clip.open(audioStream);
            clip.loop(2);
        } catch (Exception ex) {
            Toolkit.getDefaultToolkit().beep();
        }
        JOptionPane.showMessageDialog(this, "⏰ Время просыпаться!", "Будильник", JOptionPane.WARNING_MESSAGE);
        if (repeat.equals("Один раз")) active = false;
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> new AlarmClock().setVisible(true));
    }
}
