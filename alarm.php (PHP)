<?php
// alarm.php - Будильник на PHP с сессией и JS-интерфейсом
session_start();
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    if (isset($_POST['action'])) {
        if ($_POST['action'] === 'set') {
            $_SESSION['alarm'] = [
                'hour' => (int)$_POST['hour'],
                'minute' => (int)$_POST['minute'],
                'second' => (int)$_POST['second'],
                'repeat' => $_POST['repeat'],
                'active' => true
            ];
        } elseif ($_POST['action'] === 'stop') {
            unset($_SESSION['alarm']);
        } elseif ($_POST['action'] === 'snooze') {
            if (isset($_SESSION['alarm'])) {
                $snoozeTime = time() + 5*60;
                $_SESSION['alarm']['hour'] = date('H', $snoozeTime);
                $_SESSION['alarm']['minute'] = date('i', $snoozeTime);
                $_SESSION['alarm']['second'] = date('s', $snoozeTime);
                $_SESSION['alarm']['repeat'] = 'once';
            }
        }
        exit;
    }
}
$alarm = isset($_SESSION['alarm']) ? $_SESSION['alarm'] : null;
?>
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>PHP Будильник</title>
    <style>
        body { font-family: 'Segoe UI', system-ui; background: #2c3e50; display: flex; justify-content: center; align-items: center; height: 100vh; margin:0; }
        .card { background: white; border-radius: 40px; padding: 30px; width: 450px; text-align: center; box-shadow: 0 15px 30px rgba(0,0,0,0.3); }
        .clock { font-size: 56px; font-family: monospace; background: #2c3e50; color: #f1c40f; padding: 15px; border-radius: 50px; margin: 20px 0; }
        select, input, button { padding: 8px 12px; margin: 5px; border-radius: 30px; border: 1px solid #ccc; }
        button { background: #3498db; color: white; border: none; cursor: pointer; }
        .presets button { background: #2ecc71; width: 70px; }
        .status { background: #ecf0f1; padding: 8px; border-radius: 20px; margin-top: 15px; }
